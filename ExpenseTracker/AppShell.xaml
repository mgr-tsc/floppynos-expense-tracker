<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="ExpenseTracker.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:ExpenseTracker.Pages"
    Shell.FlyoutBehavior="Disabled"
    Title="ExpenseTracker">

    <ShellContent
        Title="Loading"
        ContentTemplate="{DataTemplate pages:LoadingPage}"
        Route="loading"
        Shell.FlyoutItemIsVisible="False" />

    <ShellContent
        Title="Sign In"
        ContentTemplate="{DataTemplate pages:SignInPage}"
        Route="signin"
        Shell.FlyoutItemIsVisible="False" />

    <ShellContent
        Title="Household Setup"
        ContentTemplate="{DataTemplate pages:HouseholdSetupPage}"
        Route="householdsetup"
        Shell.FlyoutItemIsVisible="False" />

    <ShellContent
        Title="Dashboard"
        Icon="{StaticResource IconDashboard}"
        ContentTemplate="{DataTemplate pages:MainPage}"
        Route="main" />

    <ShellContent
        Title="Cards"
        Icon="{StaticResource IconCards}"
        ContentTemplate="{DataTemplate pages:CardDetailPage}"
        Route="cards" />

    <ShellContent
        Title="Settings"
        Icon="{StaticResource IconSettings}"
        ContentTemplate="{DataTemplate pages:ManageProfilesPage}"
        Route="settings" />

    <ShellContent
        Title="Mock Home"
        Icon="{StaticResource IconMockHome}"
        ContentTemplate="{DataTemplate pages:MockHomePage}"
        Route="mockhome" />


</Shell>
