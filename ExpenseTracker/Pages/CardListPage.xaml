<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pageModels="clr-namespace:ExpenseTracker.PageModels"
             xmlns:models="clr-namespace:ExpenseTracker.Models.Supabase"
             xmlns:controls="clr-namespace:ExpenseTracker.Pages.Controls"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="ExpenseTracker.Pages.CardListPage"
             x:Name="CardList"
             x:DataType="pageModels:CardListPageModel"
             Title="Cards">

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior
                x:Name="AppearingBehavior"
                BindingContext="{Binding Path=BindingContext, Source={x:Reference CardList}, x:DataType=ContentPage}"
                EventName="Appearing"
                Command="{Binding AppearingCommand}" />
    </ContentPage.Behaviors>

    <Grid>
        <CollectionView ItemsSource="{Binding Cards}"
            Margin="{StaticResource LayoutPadding}"
            SelectionMode="Single"
            SelectedItem="{Binding SelectedCard}"
            SelectionChangedCommand="{Binding NavigateToCardCommand, Source={RelativeSource AncestorType={x:Type pageModels:CardListPageModel}}, x:DataType=pageModels:CardListPageModel}"
            SelectionChangedCommandParameter="{Binding SelectedCard}">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="7.5"/>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:CardDTO">
                    <Border SemanticProperties.Description="{Binding DisplayName}">
                        <VerticalStackLayout Padding="10" Spacing="4">
                            <Label Text="{Binding DisplayName}" Style="{StaticResource Body1Strong}" />
                            <Label Text="{Binding Provider}" Style="{StaticResource Caption1}" />
                            <Label Text="{Binding Profile.Name, StringFormat='Owner: {0}'}" Style="{StaticResource Caption2}" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <controls:AddButton Command="{Binding AddCardCommand}"
                            SemanticProperties.Description="Add card" />
    </Grid>
</ContentPage>
