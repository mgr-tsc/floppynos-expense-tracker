<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pageModels="clr-namespace:ExpenseTracker.PageModels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
             x:Class="ExpenseTracker.Pages.LoadingPage"
             x:DataType="pageModels:LoadingPageModel"
             x:Name="LoadPage"
             Shell.NavBarIsVisible="False"
             Shell.FlyoutItemIsVisible="False"
             BackgroundColor="{StaticResource AppBackground}">

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior
                BindingContext="{Binding Path=BindingContext, Source={x:Reference LoadPage}, x:DataType=ContentPage}"
                EventName="Appearing"
                Command="{Binding AppearingCommand}" />
    </ContentPage.Behaviors>

    <Grid RowDefinitions="*,Auto" Padding="28,48,28,24">

        <!-- ═══════════ MAIN BLOCK ═══════════ -->
        <VerticalStackLayout Grid.Row="0"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="24">

            <!-- Eyebrow -->
            <Label Text="INITIALIZING"
                   Style="{StaticResource SectionLabelStyle}"
                   HorizontalOptions="Center" />

            <!-- Title -->
            <Label Text="FLOPPYNO'S EXPENSE TRACKER"
                   FontSize="28"
                   FontFamily="SpaceGrotesk-Bold"
                   TextColor="White"
                   CharacterSpacing="-0.6"
                   LineHeight="0.98"
                   HorizontalTextAlignment="Center" />

            <!-- Subtitle -->
            <Label Text="Preparing your workspace and syncing balances..."
                   FontSize="13"
                   FontFamily="SpaceGrotesk"
                   TextColor="{StaticResource DimmedText}"
                   LineHeight="1.45"
                   HorizontalTextAlignment="Center" />

            <!-- ── Spinner ── -->
            <Grid WidthRequest="120" HeightRequest="120"
                  HorizontalOptions="Center">

                <!-- Dark base ring -->
                <Ellipse WidthRequest="120" HeightRequest="120"
                         Stroke="#1F2937"
                         StrokeThickness="10"
                         Fill="Transparent"
                         HorizontalOptions="Center"
                         VerticalOptions="Center" />

                <!-- Gold rotating arc -->
                <Ellipse x:Name="SpinnerArc"
                         WidthRequest="120" HeightRequest="120"
                         Stroke="#D4AF37"
                         StrokeThickness="10"
                         StrokeDashArray="90, 290"
                         StrokeLineCap="Round"
                         Fill="Transparent"
                         HorizontalOptions="Center"
                         VerticalOptions="Center" />

                <!-- Inner dashed accent ring (static) -->
                <Ellipse WidthRequest="88" HeightRequest="88"
                         Stroke="#D4AF37"
                         StrokeThickness="2"
                         StrokeDashArray="4, 14"
                         Fill="Transparent"
                         HorizontalOptions="Center"
                         VerticalOptions="Center" />

            </Grid>

            <!-- Dots row -->
            <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                <BoxView WidthRequest="7" HeightRequest="7"
                         CornerRadius="4"
                         Color="{StaticResource GoldAccent}" />
                <BoxView WidthRequest="7" HeightRequest="7"
                         CornerRadius="4"
                         Color="#555555" />
                <BoxView WidthRequest="7" HeightRequest="7"
                         CornerRadius="4"
                         Color="#555555" />
            </HorizontalStackLayout>

        </VerticalStackLayout>

        <!-- ═══════════ FOOTER ═══════════ -->
        <VerticalStackLayout Grid.Row="1"
                             HorizontalOptions="Center"
                             Spacing="6">
            <Label Text="Powered by Keepersoft"
                   FontSize="11"
                   FontFamily="SpaceGrotesk"
                   TextColor="#808080"
                   HorizontalOptions="Center" />
            <Label Text="© 2026 Keepersoft. All rights reserved."
                   FontSize="9"
                   FontFamily="SpaceGrotesk"
                   TextColor="{StaticResource MutedText}"
                   HorizontalOptions="Center" />
        </VerticalStackLayout>

    </Grid>

</ContentPage>
