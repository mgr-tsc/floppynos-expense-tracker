<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pageModels="clr-namespace:ExpenseTracker.PageModels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:fonts="clr-namespace:ExpenseTracker.Resources.Fonts"
             x:Class="ExpenseTracker.Pages.ExpenseDetailPage"
             x:DataType="pageModels:ExpenseDetailPageModel"
             x:Name="ExpensePage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource AppBackground}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <toolkit:InvertedBoolConverter x:Key="InvertedBoolConverter" />
            <toolkit:IsNotNullConverter x:Key="IsNotNullConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>

        <ScrollView IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}">
            <VerticalStackLayout Padding="28,8,28,36" Spacing="28">

                <!-- ═══════════ HEADER ═══════════ -->
                <Grid ColumnDefinitions="Auto,*" Padding="0,16,0,4">

                    <Border Grid.Column="0"
                            WidthRequest="40" HeightRequest="40"
                            Background="{StaticResource CardSurface}"
                            Stroke="{StaticResource StrokeColor}"
                            StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBackTapped" />
                        </Border.GestureRecognizers>
                        <Label Text="{x:Static fonts:FluentUi.arrow_left_24_regular}"
                               FontFamily="{x:Static fonts:FluentUi.fontFamily}"
                               FontSize="18"
                               TextColor="White"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>

                    <VerticalStackLayout Grid.Column="1" Margin="16,0,0,0" VerticalOptions="Center" Spacing="2">
                        <Label Text="EXPENSE" Style="{StaticResource SectionLabelStyle}" />
                        <Label Text="{Binding PageTitle}"
                               FontSize="26"
                               FontFamily="SpaceGrotesk-Bold"
                               TextColor="White" />
                    </VerticalStackLayout>

                </Grid>

                <!-- ═══════════ FORM ═══════════ -->
                <VerticalStackLayout Spacing="16">

                    <!-- Section header -->
                    <Grid ColumnDefinitions="3,*">
                        <BoxView Grid.Column="0"
                                 WidthRequest="3" HeightRequest="18"
                                 Color="{StaticResource GoldAccent}"
                                 VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="CHARGE DETAILS"
                               Style="{StaticResource SectionLabelStyle}"
                               Margin="10,0,0,0"
                               VerticalOptions="Center" />
                    </Grid>

                    <!-- DESCRIPTION -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="DESCRIPTION" Style="{StaticResource SectionLabelStyle}" />
                        <Grid RowDefinitions="52,2" BackgroundColor="{StaticResource CardSurface}">
                            <Entry Grid.Row="0"
                                   Text="{Binding Description}"
                                   IsReadOnly="{Binding IsEditable, Converter={StaticResource InvertedBoolConverter}}"
                                   BackgroundColor="Transparent"
                                   TextColor="White"
                                   PlaceholderColor="{StaticResource MutedText}"
                                   Placeholder="e.g., Grocery run"
                                   FontFamily="SpaceGrotesk"
                                   FontSize="14"
                                   Margin="18,0" />
                            <BoxView Grid.Row="1" Color="{StaticResource StrokeColor}" />
                        </Grid>
                    </VerticalStackLayout>

                    <!-- PAYMENT METHOD (Card) -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="PAYMENT METHOD" Style="{StaticResource SectionLabelStyle}" />
                        <Grid RowDefinitions="52,2" BackgroundColor="{StaticResource CardSurface}">
                            <Picker Grid.Row="0"
                                    ItemsSource="{Binding Cards}"
                                    SelectedIndex="{Binding CardIndex}"
                                    IsEnabled="{Binding IsEditable}"
                                    Title="Select card"
                                    TitleColor="{StaticResource MutedText}"
                                    TextColor="White"
                                    BackgroundColor="Transparent"
                                    HeightRequest="52"
                                    Margin="4,0" />
                            <BoxView Grid.Row="1" Color="{StaticResource StrokeColor}" />
                        </Grid>
                    </VerticalStackLayout>

                    <!-- AMOUNT -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="AMOUNT (US$)" Style="{StaticResource SectionLabelStyle}" />
                        <Grid RowDefinitions="52,2" ColumnDefinitions="*,Auto"
                              BackgroundColor="{StaticResource CardSurface}">
                            <Entry Grid.Row="0" Grid.Column="0"
                                   Text="{Binding Amount}"
                                   Keyboard="Numeric"
                                   IsReadOnly="{Binding IsEditable, Converter={StaticResource InvertedBoolConverter}}"
                                   BackgroundColor="Transparent"
                                   TextColor="White"
                                   PlaceholderColor="{StaticResource MutedText}"
                                   Placeholder="0.00"
                                   FontFamily="SpaceGrotesk"
                                   FontSize="15"
                                   Margin="18,0" />
                            <Label Grid.Row="0" Grid.Column="1"
                                   Text="$"
                                   FontFamily="SpaceGrotesk-Bold"
                                   FontSize="16"
                                   TextColor="{StaticResource GoldAccent}"
                                   VerticalOptions="Center"
                                   Margin="0,0,18,0" />
                            <BoxView Grid.Row="1" Grid.ColumnSpan="2"
                                     Color="{StaticResource GoldAccent}" />
                        </Grid>
                    </VerticalStackLayout>

                    <!-- SPLIT POLICY -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="SPLIT POLICY" Style="{StaticResource SectionLabelStyle}" />
                        <Grid RowDefinitions="52,2" BackgroundColor="{StaticResource CardSurface}">
                            <Picker Grid.Row="0"
                                    ItemsSource="{Binding SplitOptions}"
                                    SelectedIndex="{Binding SplitOptionIndex}"
                                    IsEnabled="{Binding IsEditable}"
                                    Title="Select split policy"
                                    TitleColor="{StaticResource MutedText}"
                                    TextColor="White"
                                    BackgroundColor="Transparent"
                                    HeightRequest="52"
                                    Margin="4,0" />
                            <BoxView Grid.Row="1" Color="{StaticResource StrokeColor}" />
                        </Grid>
                    </VerticalStackLayout>

                    <!-- CATEGORY -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="CATEGORY" Style="{StaticResource SectionLabelStyle}" />
                        <Grid RowDefinitions="52,2" ColumnDefinitions="*,Auto"
                              BackgroundColor="{StaticResource CardSurface}">
                            <Picker Grid.Row="0" Grid.Column="0"
                                    ItemsSource="{Binding Categories}"
                                    SelectedIndex="{Binding CategoryIndex}"
                                    IsEnabled="{Binding IsEditable}"
                                    Title="Select category"
                                    TitleColor="{StaticResource MutedText}"
                                    TextColor="White"
                                    BackgroundColor="Transparent"
                                    HeightRequest="52"
                                    Margin="4,0" />
                            <!-- + NEW button -->
                            <Border Grid.Row="0" Grid.Column="1"
                                    IsVisible="{Binding IsEditable}"
                                    Background="{StaticResource ElevatedSurface}"
                                    Stroke="{StaticResource StrokeColor}"
                                    StrokeThickness="1"
                                    Margin="8,12,12,12">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding AddCategoryCommand}" />
                                </Border.GestureRecognizers>
                                <HorizontalStackLayout Spacing="4" Padding="10,0">
                                    <Label Text="{x:Static fonts:FluentUi.add_circle_20_regular}"
                                           FontFamily="{x:Static fonts:FluentUi.fontFamily}"
                                           FontSize="12"
                                           TextColor="{StaticResource GoldAccent}"
                                           VerticalOptions="Center" />
                                    <Label Text="NEW"
                                           FontFamily="SpaceGrotesk-Bold"
                                           FontSize="10"
                                           TextColor="{StaticResource GoldAccent}"
                                           CharacterSpacing="1.5"
                                           VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </Border>
                            <BoxView Grid.Row="1" Grid.ColumnSpan="2"
                                     Color="{StaticResource StrokeColor}" />
                        </Grid>
                    </VerticalStackLayout>

                    <!-- DATE -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="DATE" Style="{StaticResource SectionLabelStyle}" />
                        <Grid RowDefinitions="52,2" BackgroundColor="{StaticResource CardSurface}">
                            <DatePicker Grid.Row="0"
                                        Date="{Binding Date}"
                                        IsEnabled="{Binding IsEditable}"
                                        BackgroundColor="Transparent"
                                        TextColor="White"
                                        Format="MMM d, yyyy"
                                        FontFamily="SpaceGrotesk"
                                        FontSize="15"
                                        HeightRequest="52"
                                        Margin="18,0" />
                            <BoxView Grid.Row="1" Color="{StaticResource StrokeColor}" />
                        </Grid>
                    </VerticalStackLayout>

                </VerticalStackLayout>

                <!-- ═══════════ CTA SECTION ═══════════ -->
                <VerticalStackLayout Spacing="12">

                    <!-- Error -->
                    <Label Text="{Binding ErrorMessage}"
                           TextColor="#E05555"
                           FontSize="12"
                           FontFamily="SpaceGrotesk"
                           IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}"
                           HorizontalOptions="Center" />

                    <!-- CREATE CHARGE (new charge) -->
                    <Button Text="CREATE CHARGE"
                            HeightRequest="56"
                            Command="{Binding SaveCommand}"
                            IsVisible="{Binding IsExisting, Converter={StaticResource InvertedBoolConverter}}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                            BackgroundColor="{StaticResource GoldAccent}"
                            TextColor="{StaticResource AppBackground}"
                            FontFamily="SpaceGrotesk-Bold"
                            FontSize="14"
                            CharacterSpacing="2"
                            CornerRadius="12">
                        <Button.ImageSource>
                            <FontImageSource Glyph="{x:Static fonts:FluentUi.add_circle_20_regular}"
                                             FontFamily="{x:Static fonts:FluentUi.fontFamily}"
                                             Size="18"
                                             Color="{StaticResource AppBackground}" />
                        </Button.ImageSource>
                    </Button>

                    <!-- RE-SUBMIT (owner editing a rejected charge) -->
                    <Button Text="RE-SUBMIT"
                            HeightRequest="56"
                            Command="{Binding SaveCommand}"
                            IsVisible="{Binding CanResubmit}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                            BackgroundColor="{StaticResource GoldAccent}"
                            TextColor="{StaticResource AppBackground}"
                            FontFamily="SpaceGrotesk-Bold"
                            FontSize="14"
                            CharacterSpacing="2"
                            CornerRadius="12">
                        <Button.ImageSource>
                            <FontImageSource Glyph="{x:Static fonts:FluentUi.arrow_upload_20_regular}"
                                             FontFamily="{x:Static fonts:FluentUi.fontFamily}"
                                             Size="18"
                                             Color="{StaticResource AppBackground}" />
                        </Button.ImageSource>
                    </Button>

                    <!-- APPROVE / REJECT (partner's pending charge) -->
                    <HorizontalStackLayout Spacing="12"
                                           HorizontalOptions="Fill"
                                           IsVisible="{Binding CanApprove}">
                        <Button Text="APPROVE"
                                HorizontalOptions="FillAndExpand"
                                HeightRequest="56"
                                Command="{Binding ApproveCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                                BackgroundColor="#2D5A2D"
                                TextColor="White"
                                FontFamily="SpaceGrotesk-Bold"
                                FontSize="13"
                                CharacterSpacing="1"
                                CornerRadius="12" />
                        <Button Text="REJECT"
                                HorizontalOptions="FillAndExpand"
                                HeightRequest="56"
                                Command="{Binding RejectCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                                BackgroundColor="#5A2D2D"
                                TextColor="White"
                                FontFamily="SpaceGrotesk-Bold"
                                FontSize="13"
                                CharacterSpacing="1"
                                CornerRadius="12" />
                    </HorizontalStackLayout>

                    <!-- CANCEL -->
                    <Button Text="CANCEL"
                            HeightRequest="48"
                            Clicked="OnCancelTapped"
                            BackgroundColor="Transparent"
                            BorderColor="{StaticResource StrokeColor}"
                            BorderWidth="1"
                            TextColor="{StaticResource MutedText}"
                            FontFamily="SpaceGrotesk"
                            FontSize="12"
                            CharacterSpacing="2"
                            CornerRadius="12" />

                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Loading overlay -->
        <ActivityIndicator IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           Color="{StaticResource GoldAccent}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />

    </Grid>

</ContentPage>
