<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pageModels="clr-namespace:ExpenseTracker.PageModels"
             xmlns:sf="clr-namespace:Syncfusion.Maui.Toolkit.TextInputLayout;assembly=Syncfusion.Maui.Toolkit"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="ExpenseTracker.Pages.CreateHouseholdPage"
             x:DataType="pageModels:CreateHouseholdPageModel"
             Title="Create Household">

    <ContentPage.Resources>
        <ResourceDictionary>
            <toolkit:InvertedBoolConverter x:Key="InvertedBoolConverter" />
            <toolkit:IsNotNullConverter x:Key="IsNotNullConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="{StaticResource LayoutPadding}"
                             Spacing="{StaticResource LayoutSpacing}"
                             VerticalOptions="Center">

            <Label Text="Create Your Household"
                   Style="{StaticResource LargeTitle}"
                   HorizontalOptions="Center"
                   Margin="0,0,0,20" />

            <!-- Input Section - Hidden when code is visible -->
            <VerticalStackLayout IsVisible="{Binding IsCodeVisible, Converter={StaticResource InvertedBoolConverter}}"
                                 Spacing="{StaticResource LayoutSpacing}">

                <sf:SfTextInputLayout Hint="Household Name">
                    <Entry Text="{Binding HouseholdName}"
                           SemanticProperties.Description="Household name" />
                </sf:SfTextInputLayout>

                <Label Text="{Binding ErrorMessage}"
                       TextColor="Red"
                       IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}"
                       HorizontalOptions="Center" />

                <Button Text="Create Household"
                        Command="{Binding CreateCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                        MinimumHeightRequest="{OnIdiom 48, Desktop=56}"
                        HorizontalOptions="Center"
                        Padding="24,12" />

                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- Code Display Section - Shown after creation -->
            <VerticalStackLayout IsVisible="{Binding IsCodeVisible}"
                                 Spacing="{StaticResource LayoutSpacing}">

                <Label Text="Household Created!"
                       FontSize="20"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="Green" />

                <Label Text="Share this code with your partner to join:"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       Margin="0,10,0,10" />

                <Border BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#2E2E2E}"
                       Padding="20"
                       HorizontalOptions="Center">
                    <Label Text="{Binding GeneratedCode}"
                           FontSize="32"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           SemanticProperties.Description="Join code" />
                </Border>

                <Button Text="Copy Code"
                        Command="{Binding CopyCodeCommand}"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource Primary}"
                        HorizontalOptions="Center"
                        Padding="24,12" />

                <Button Text="Continue to Dashboard"
                        Command="{Binding ContinueCommand}"
                        MinimumHeightRequest="{OnIdiom 48, Desktop=56}"
                        HorizontalOptions="Center"
                        Padding="24,12"
                        Margin="0,20,0,0" />
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>