<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pageModels="clr-namespace:ExpenseTracker.PageModels"
             x:Class="ExpenseTracker.Pages.HouseholdSetupPage"
             x:DataType="pageModels:HouseholdSetupPageModel"
             Shell.NavBarIsVisible="False"
             Shell.FlyoutItemIsVisible="False"
             Title="Household Setup">

    <VerticalStackLayout VerticalOptions="Center"
                         Padding="{StaticResource LayoutPadding}"
                         Spacing="{StaticResource LayoutSpacing}">

        <Label Text="Welcome to Expense Tracker"
               Style="{StaticResource LargeTitle}"
               HorizontalOptions="Center"
               Margin="0,0,0,20" />

        <Label Text="To get started, create a new household or join an existing one."
               HorizontalOptions="Center"
               HorizontalTextAlignment="Center"
               Margin="0,0,0,40" />

        <Button Command="{Binding CreateHouseholdCommand}"
                Text="Create New Household"
                MinimumHeightRequest="{OnIdiom 48, Desktop=56}"
                HorizontalOptions="Center"
                Padding="24,12"
                SemanticProperties.Description="Create a new household" />

        <Button Command="{Binding JoinHouseholdCommand}"
                Text="Join Existing Household"
                BackgroundColor="Transparent"
                TextColor="{StaticResource Primary}"
                MinimumHeightRequest="{OnIdiom 48, Desktop=56}"
                HorizontalOptions="Center"
                Padding="24,12"
                SemanticProperties.Description="Join an existing household with a code" />

    </VerticalStackLayout>
</ContentPage>