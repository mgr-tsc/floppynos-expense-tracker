<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pageModels="clr-namespace:ExpenseTracker.PageModels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:fonts="clr-namespace:ExpenseTracker.Resources.Fonts"
             x:Class="ExpenseTracker.Pages.HouseholdSetupPage"
             x:DataType="pageModels:HouseholdSetupPageModel"
             Shell.NavBarIsVisible="False"
             Shell.FlyoutItemIsVisible="False"
             BackgroundColor="{StaticResource AppBackground}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <toolkit:InvertedBoolConverter x:Key="InvertedBoolConverter" />
            <toolkit:IsNotNullConverter x:Key="IsNotNullConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>

        <ScrollView>
            <VerticalStackLayout Padding="28,34,28,40" Spacing="20">

                <!-- ═══════════ HERO ═══════════ -->
                <VerticalStackLayout Spacing="8" Margin="0,0,0,8">
                    <Label Text="SETUP"
                           Style="{StaticResource SectionLabelStyle}" />
                    <Label Text="HOUSEHOLD"
                           FontSize="32"
                           FontFamily="SpaceGrotesk-Bold"
                           TextColor="White"
                           CharacterSpacing="-1"
                           LineHeight="0.95" />
                    <Label Text="Create a new household or join an existing one to start sharing expenses."
                           FontSize="13"
                           FontFamily="SpaceGrotesk"
                           TextColor="{StaticResource DimmedText}"
                           LineHeight="1.45" />
                </VerticalStackLayout>

                <!-- ═══════════ JOIN CARD ═══════════ -->
                <Border Background="{StaticResource CardSurface}"
                        Stroke="{StaticResource StrokeColor}"
                        StrokeThickness="1"
                        Padding="16,18">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="12">

                        <!-- Card header -->
                        <Grid ColumnDefinitions="3,*">
                            <BoxView Grid.Column="0"
                                     WidthRequest="3" HeightRequest="14"
                                     Color="{StaticResource GoldAccent}"
                                     VerticalOptions="Center" />
                            <Label Grid.Column="1"
                                   Text="JOIN HOUSEHOLD"
                                   Style="{StaticResource SectionLabelStyle}"
                                   FontSize="11"
                                   Margin="10,0,0,0"
                                   VerticalOptions="Center" />
                        </Grid>

                        <!-- Code entry -->
                        <Label Text="ENTER 5-DIGIT CODE" Style="{StaticResource SectionLabelStyle}" />
                        <Border Background="{StaticResource AppBackground}"
                                Stroke="{StaticResource GoldAccent}"
                                StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Entry Text="{Binding Code}"
                                   Keyboard="Numeric"
                                   MaxLength="5"
                                   BackgroundColor="Transparent"
                                   TextColor="White"
                                   PlaceholderColor="{StaticResource MutedText}"
                                   Placeholder="00000"
                                   FontFamily="JetBrainsMono-Bold"
                                   FontSize="24"
                                   HorizontalTextAlignment="Center"
                                   HeightRequest="52" />
                        </Border>

                        <!-- Join error -->
                        <Label Text="{Binding JoinErrorMessage}"
                               TextColor="#E05555"
                               FontSize="12"
                               FontFamily="SpaceGrotesk"
                               IsVisible="{Binding JoinErrorMessage, Converter={StaticResource IsNotNullConverter}}"
                               HorizontalOptions="Center" />

                        <!-- JOIN button -->
                        <Button Text="JOIN HOUSEHOLD"
                                HeightRequest="52"
                                Command="{Binding JoinCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                                BackgroundColor="{StaticResource GoldAccent}"
                                TextColor="{StaticResource AppBackground}"
                                FontFamily="SpaceGrotesk-Bold"
                                FontSize="12"
                                CharacterSpacing="1.6"
                                CornerRadius="10">
                            <Button.ImageSource>
                                <FontImageSource Glyph="{x:Static fonts:FluentUi.person_add_20_regular}"
                                                 FontFamily="{x:Static fonts:FluentUi.fontFamily}"
                                                 Size="16"
                                                 Color="{StaticResource AppBackground}" />
                            </Button.ImageSource>
                        </Button>

                    </VerticalStackLayout>
                </Border>

                <!-- ═══════════ OR DIVIDER ═══════════ -->
                <Label Text="OR"
                       Style="{StaticResource SectionLabelStyle}"
                       HorizontalOptions="Center" />

                <!-- ═══════════ CREATE CARD ═══════════ -->
                <Border Background="{StaticResource CardSurface}"
                        Stroke="{StaticResource StrokeColor}"
                        StrokeThickness="1"
                        Padding="16,18">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="12">

                        <!-- Card header -->
                        <Grid ColumnDefinitions="3,*">
                            <BoxView Grid.Column="0"
                                     WidthRequest="3" HeightRequest="14"
                                     Color="{StaticResource MutedText}"
                                     VerticalOptions="Center" />
                            <Label Grid.Column="1"
                                   Text="CREATE HOUSEHOLD"
                                   Style="{StaticResource SectionLabelStyle}"
                                   FontSize="11"
                                   Margin="10,0,0,0"
                                   VerticalOptions="Center" />
                        </Grid>

                        <!-- Input section (hidden when code visible) -->
                        <VerticalStackLayout Spacing="12"
                                             IsVisible="{Binding IsCodeVisible, Converter={StaticResource InvertedBoolConverter}}">

                            <!-- Name field -->
                            <Label Text="HOUSEHOLD NAME" Style="{StaticResource SectionLabelStyle}" />
                            <Grid RowDefinitions="52,2" ColumnDefinitions="*,Auto"
                                  BackgroundColor="{StaticResource AppBackground}">
                                <Entry Grid.Row="0" Grid.Column="0"
                                       Text="{Binding HouseholdName}"
                                       BackgroundColor="Transparent"
                                       TextColor="White"
                                       PlaceholderColor="{StaticResource MutedText}"
                                       Placeholder="e.g. Roommates NYC"
                                       FontFamily="SpaceGrotesk"
                                       FontSize="15"
                                       Margin="16,0" />
                                <Label Grid.Row="0" Grid.Column="1"
                                       Text="{x:Static fonts:FluentUi.home_20_regular}"
                                       FontFamily="{x:Static fonts:FluentUi.fontFamily}"
                                       FontSize="16"
                                       TextColor="{StaticResource MutedText}"
                                       VerticalOptions="Center"
                                       Margin="0,0,16,0" />
                                <BoxView Grid.Row="1" Grid.ColumnSpan="2"
                                         Color="{StaticResource StrokeColor}" />
                            </Grid>

                            <!-- Create error -->
                            <Label Text="{Binding CreateErrorMessage}"
                                   TextColor="#E05555"
                                   FontSize="12"
                                   FontFamily="SpaceGrotesk"
                                   IsVisible="{Binding CreateErrorMessage, Converter={StaticResource IsNotNullConverter}}"
                                   HorizontalOptions="Center" />

                            <!-- CREATE button -->
                            <Button Text="CREATE HOUSEHOLD"
                                    HeightRequest="52"
                                    Command="{Binding CreateCommand}"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                                    BackgroundColor="Transparent"
                                    BorderColor="{StaticResource StrokeColor}"
                                    BorderWidth="1"
                                    TextColor="{StaticResource DimmedText}"
                                    FontFamily="SpaceGrotesk-Bold"
                                    FontSize="12"
                                    CharacterSpacing="1.5"
                                    CornerRadius="10">
                                <Button.ImageSource>
                                    <FontImageSource Glyph="{x:Static fonts:FluentUi.add_circle_20_regular}"
                                                     FontFamily="{x:Static fonts:FluentUi.fontFamily}"
                                                     Size="16"
                                                     Color="{StaticResource DimmedText}" />
                                </Button.ImageSource>
                            </Button>

                        </VerticalStackLayout>

                        <!-- Success section (shown after creation) -->
                        <VerticalStackLayout Spacing="16" IsVisible="{Binding IsCodeVisible}">

                            <VerticalStackLayout Spacing="6">
                                <Label Text="HOUSEHOLD CREATED"
                                       Style="{StaticResource SectionLabelStyle}"
                                       TextColor="#4CAF50" />
                                <Label Text="Share this code with your partner to join:"
                                       FontSize="13"
                                       FontFamily="SpaceGrotesk"
                                       TextColor="{StaticResource DimmedText}" />
                            </VerticalStackLayout>

                            <!-- Generated code display -->
                            <Border Background="{StaticResource AppBackground}"
                                    Stroke="{StaticResource GoldAccent}"
                                    StrokeThickness="1"
                                    HorizontalOptions="Center"
                                    Padding="32,14">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12" />
                                </Border.StrokeShape>
                                <Label Text="{Binding GeneratedCode}"
                                       FontFamily="JetBrainsMono-Bold"
                                       FontSize="32"
                                       TextColor="{StaticResource GoldAccent}"
                                       HorizontalOptions="Center" />
                            </Border>

                            <!-- Copy code -->
                            <Button Text="COPY CODE"
                                    HeightRequest="44"
                                    Command="{Binding CopyCodeCommand}"
                                    BackgroundColor="Transparent"
                                    BorderColor="{StaticResource StrokeColor}"
                                    BorderWidth="1"
                                    TextColor="{StaticResource DimmedText}"
                                    FontFamily="SpaceGrotesk"
                                    FontSize="11"
                                    CharacterSpacing="2"
                                    CornerRadius="10" />

                            <!-- Continue -->
                            <Button Text="CONTINUE TO DASHBOARD"
                                    HeightRequest="52"
                                    Command="{Binding ContinueCommand}"
                                    BackgroundColor="{StaticResource GoldAccent}"
                                    TextColor="{StaticResource AppBackground}"
                                    FontFamily="SpaceGrotesk-Bold"
                                    FontSize="12"
                                    CharacterSpacing="1.5"
                                    CornerRadius="10" />

                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

                <!-- ═══════════ FOOTNOTE ═══════════ -->
                <Label Text="Only household owners can share invite codes."
                       FontSize="10"
                       FontFamily="SpaceGrotesk"
                       TextColor="{StaticResource MutedText}"
                       LineHeight="1.45" />

            </VerticalStackLayout>
        </ScrollView>

        <!-- Loading overlay -->
        <ActivityIndicator IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           Color="{StaticResource GoldAccent}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />

    </Grid>

</ContentPage>
