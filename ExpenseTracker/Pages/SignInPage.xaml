<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pageModels="clr-namespace:ExpenseTracker.PageModels"
             xmlns:sf="clr-namespace:Syncfusion.Maui.Toolkit.TextInputLayout;assembly=Syncfusion.Maui.Toolkit"
             x:Class="ExpenseTracker.Pages.SignInPage"
             x:DataType="pageModels:SignInPageModel"
             Shell.NavBarIsVisible="False"
             Shell.FlyoutItemIsVisible="False"
             Title="Sign In">

    <VerticalStackLayout VerticalOptions="Center"
                         Padding="{StaticResource LayoutPadding}"
                         Spacing="{StaticResource LayoutSpacing}">
        <Label Text="Expense Tracker"
               Style="{StaticResource LargeTitle}"
               HorizontalOptions="Center"
               Margin="0,0,0,30" />

        <sf:SfTextInputLayout Hint="Email">
            <Entry Text="{Binding Email}"
                   Keyboard="Email"
                   SemanticProperties.Description="Email" />
        </sf:SfTextInputLayout>

        <sf:SfTextInputLayout Hint="Password">
            <Entry Text="{Binding Password}"
                   IsPassword="True"
                   SemanticProperties.Description="Password" />
        </sf:SfTextInputLayout>

        <Button Text="Sign In"
                Command="{Binding SignInCommand}"
                MinimumHeightRequest="{OnIdiom 44, Desktop=60}"
                Margin="0,20,0,0" />
    </VerticalStackLayout>
</ContentPage>
