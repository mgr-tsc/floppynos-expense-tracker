<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pageModels="clr-namespace:ExpenseTracker.PageModels"
             xmlns:fonts="clr-namespace:ExpenseTracker.Resources.Fonts"
             x:Class="ExpenseTracker.Pages.SignInPage"
             x:DataType="pageModels:SignInPageModel"
             Shell.NavBarIsVisible="False"
             Shell.FlyoutItemIsVisible="False"
             BackgroundColor="{StaticResource AppBackground}">

    <ScrollView>
        <VerticalStackLayout Padding="28,40" Spacing="28">

            <!-- ═══════════ HERO ═══════════ -->
            <VerticalStackLayout Spacing="8">
                <Label Text="WELCOME"
                       Style="{StaticResource SectionLabelStyle}" />
                <Label Text="FLOPPYNOS"
                       FontSize="34"
                       FontFamily="SpaceGrotesk-Bold"
                       TextColor="White"
                       CharacterSpacing="-1"
                       LineHeight="0.95" />
                <Label Text="Track shared expenses, split payments, and keep every charge in sync."
                       FontSize="14"
                       FontFamily="SpaceGrotesk"
                       TextColor="{StaticResource DimmedText}"
                       LineHeight="1.45" />
            </VerticalStackLayout>

            <!-- ═══════════ AUTH INFO CARD ═══════════ -->
            <Border Background="{StaticResource CardSurface}"
                    Stroke="{StaticResource StrokeColor}"
                    StrokeThickness="1"
                    Padding="18,20">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="14">

                    <!-- Card header -->
                    <Grid ColumnDefinitions="3,*">
                        <BoxView Grid.Column="0"
                                 WidthRequest="3" HeightRequest="14"
                                 Color="{StaticResource GoldAccent}"
                                 VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="GET STARTED"
                               Style="{StaticResource SectionLabelStyle}"
                               FontSize="11"
                               Margin="12,0,0,0"
                               VerticalOptions="Center" />
                    </Grid>

                    <!-- Benefit 1 -->
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="{x:Static fonts:FluentUi.shield_20_regular}"
                               FontFamily="{x:Static fonts:FluentUi.fontFamily}"
                               FontSize="16"
                               TextColor="{StaticResource GoldAccent}"
                               VerticalOptions="Center" />
                        <Label Text="Secure authentication with Google"
                               FontSize="13"
                               FontFamily="SpaceGrotesk"
                               TextColor="White"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <!-- Benefit 2 -->
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="{x:Static fonts:FluentUi.sparkle_20_regular}"
                               FontFamily="{x:Static fonts:FluentUi.fontFamily}"
                               FontSize="16"
                               TextColor="{StaticResource GoldAccent}"
                               VerticalOptions="Center" />
                        <Label Text="Create your account in seconds"
                               FontSize="13"
                               FontFamily="SpaceGrotesk"
                               TextColor="White"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Border>

            <!-- ═══════════ GOOGLE BUTTON ═══════════ -->
            <Button Text="CONTINUE WITH GOOGLE"
                    HeightRequest="56"
                    Command="{Binding SignInWithGoogleCommand}"
                    BackgroundColor="White"
                    TextColor="#111111"
                    FontFamily="SpaceGrotesk-Bold"
                    FontSize="13"
                    CharacterSpacing="1.6"
                    CornerRadius="12"
                    ImageSource="google_logo.png"
                    ContentLayout="Left,12" />

            <!-- ═══════════ SECURITY NOTE ═══════════ -->
            <Border Background="{StaticResource CardSurface}"
                    Stroke="{StaticResource StrokeColor}"
                    StrokeThickness="1"
                    Padding="14,12">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <HorizontalStackLayout Spacing="10">
                    <Label Text="{x:Static fonts:FluentUi.lock_closed_20_regular}"
                           FontFamily="{x:Static fonts:FluentUi.fontFamily}"
                           FontSize="14"
                           TextColor="{StaticResource MutedText}"
                           VerticalOptions="Center" />
                    <Label Text="By continuing, you agree to our Terms and Privacy Policy."
                           FontSize="10"
                           FontFamily="SpaceGrotesk"
                           TextColor="{StaticResource MutedText}"
                           LineHeight="1.5"
                           VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
