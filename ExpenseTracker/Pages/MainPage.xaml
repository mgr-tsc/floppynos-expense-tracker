<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pageModels="clr-namespace:ExpenseTracker.PageModels"
             xmlns:models="clr-namespace:ExpenseTracker.Models.Supabase"
             xmlns:controls="clr-namespace:ExpenseTracker.Pages.Controls"
             xmlns:pullToRefresh="clr-namespace:Syncfusion.Maui.Toolkit.PullToRefresh;assembly=Syncfusion.Maui.Toolkit"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:fonts="clr-namespace:ExpenseTracker.Resources.Fonts"
             x:Class="ExpenseTracker.Pages.MainPage"
             x:DataType="pageModels:MainPageModel"
             x:Name="OverviewPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource AppBackground}">

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior
                BindingContext="{Binding Path=BindingContext, Source={x:Reference OverviewPage}, x:DataType=ContentPage}"
                EventName="NavigatedTo"
                Command="{Binding NavigatedToCommand}" />
        <toolkit:EventToCommandBehavior
                BindingContext="{Binding Path=BindingContext, Source={x:Reference OverviewPage}, x:DataType=ContentPage}"
                EventName="NavigatedFrom"
                Command="{Binding NavigatedFromCommand}" />
        <toolkit:EventToCommandBehavior
                BindingContext="{Binding Path=BindingContext, Source={x:Reference OverviewPage}, x:DataType=ContentPage}"
                EventName="Appearing"
                Command="{Binding AppearingCommand}" />
    </ContentPage.Behaviors>

    <ContentPage.Resources>
        <ResourceDictionary>
            <toolkit:InvertedBoolConverter x:Key="InvertedBoolConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>
        <pullToRefresh:SfPullToRefresh
            IsRefreshing="{Binding IsRefreshing, Mode=TwoWay}"
            Refreshing="OnRefreshing">
            <pullToRefresh:SfPullToRefresh.PullableContent>
                <ScrollView Padding="0,0,0,90">
                    <VerticalStackLayout Padding="20,8,20,28" Spacing="24">

                        <!-- Header: username + initials avatar -->
                        <controls:HeaderBar
                            UserName="{Binding UserName}"
                            UserInitials="{Binding UserInitials}" />

                        <!-- Household indicator + Filters pill -->
                        <Grid ColumnDefinitions="*,Auto">
                            <controls:HouseholdSwitcher Grid.Column="0" HouseholdName="{Binding HouseholdName}" />
                            <Border Grid.Column="1"
                                    Background="{StaticResource CardSurface}"
                                    Stroke="{StaticResource StrokeColor}"
                                    StrokeThickness="1"
                                    Padding="12,7"
                                    HorizontalOptions="End">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="20" />
                                </Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnFiltersTapped" />
                                </Border.GestureRecognizers>
                                <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                    <Label Text="{x:Static fonts:FluentUi.options_20_regular}"
                                           FontFamily="{x:Static fonts:FluentUi.fontFamily}"
                                           FontSize="16"
                                           TextColor="{StaticResource GoldAccent}"
                                           VerticalOptions="Center" />
                                    <Label Text="Filters"
                                           FontFamily="SpaceGrotesk"
                                           FontSize="13"
                                           TextColor="White"
                                           VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </Border>
                        </Grid>

                        <!-- Balance card -->
                        <controls:BalanceView BindingContext="{Binding Balance}" />

                        <!-- ═══════════ CHARGES SECTION ═══════════ -->
                        <VerticalStackLayout Spacing="14">

                            <!-- Section header -->
                            <Grid ColumnDefinitions="*,Auto">
                                <HorizontalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                                    <HorizontalStackLayout.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ToggleChargesCommand}" />
                                    </HorizontalStackLayout.GestureRecognizers>
                                    <Label Text="{x:Static fonts:FluentUi.chevron_down_20_regular}"
                                           IsVisible="{Binding IsChargesExpanded}"
                                           FontFamily="{x:Static fonts:FluentUi.fontFamily}"
                                           FontSize="14"
                                           TextColor="{StaticResource MutedText}"
                                           VerticalOptions="Center" />
                                    <Label Text="{x:Static fonts:FluentUi.chevron_right_20_regular}"
                                           IsVisible="{Binding IsChargesExpanded, Converter={StaticResource InvertedBoolConverter}}"
                                           FontFamily="{x:Static fonts:FluentUi.fontFamily}"
                                           FontSize="14"
                                           TextColor="{StaticResource MutedText}"
                                           VerticalOptions="Center" />
                                    <Label Text="Charges"
                                           Style="{StaticResource SectionLabelStyle}"
                                           FontSize="13"
                                           TextColor="{StaticResource DimmedText}"
                                           VerticalOptions="Center" />
                                </HorizontalStackLayout>
                                <Button Grid.Column="1"
                                        Text="+ NEW"
                                        Command="{Binding AddExpenseCommand}"
                                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                                        BackgroundColor="Transparent"
                                        BorderColor="{StaticResource StrokeColor}"
                                        BorderWidth="1"
                                        TextColor="{StaticResource GoldAccent}"
                                        CornerRadius="12"
                                        FontSize="11"
                                        Padding="10,4"
                                        HeightRequest="28" />
                            </Grid>

                            <!-- Collapsible content -->
                            <VerticalStackLayout IsVisible="{Binding IsChargesExpanded}" Spacing="14">

                                <!-- Charges filter: native Grid guarantees equal-width tabs at any screen size -->
                                <Border Background="{StaticResource CardSurface}"
                                        Stroke="{StaticResource StrokeColor}"
                                        StrokeThickness="1"
                                        Padding="3">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12" />
                                    </Border.StrokeShape>
                                    <Grid ColumnDefinitions="*,*,*,*">
                                        <Border Grid.Column="0" Background="Transparent" StrokeThickness="0" Padding="0,8">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="9"/></Border.StrokeShape>
                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border" Binding="{Binding SelectedStatusIndex}" Value="0">
                                                    <Setter Property="Background" Value="{StaticResource GoldAccent}"/>
                                                </DataTrigger>
                                            </Border.Triggers>
                                            <Label Text="All" FontSize="11" HorizontalOptions="Center" TextColor="{StaticResource DimmedText}">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label" Binding="{Binding SelectedStatusIndex}" Value="0">
                                                        <Setter Property="TextColor" Value="{StaticResource AppBackground}"/>
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnChargesFilterTapped" CommandParameter="0"/>
                                            </Border.GestureRecognizers>
                                        </Border>
                                        <Border Grid.Column="1" Background="Transparent" StrokeThickness="0" Padding="0,8">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="9"/></Border.StrokeShape>
                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border" Binding="{Binding SelectedStatusIndex}" Value="1">
                                                    <Setter Property="Background" Value="{StaticResource GoldAccent}"/>
                                                </DataTrigger>
                                            </Border.Triggers>
                                            <Label Text="Pending" FontSize="11" HorizontalOptions="Center" TextColor="{StaticResource DimmedText}">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label" Binding="{Binding SelectedStatusIndex}" Value="1">
                                                        <Setter Property="TextColor" Value="{StaticResource AppBackground}"/>
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnChargesFilterTapped" CommandParameter="1"/>
                                            </Border.GestureRecognizers>
                                        </Border>
                                        <Border Grid.Column="2" Background="Transparent" StrokeThickness="0" Padding="0,8">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="9"/></Border.StrokeShape>
                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border" Binding="{Binding SelectedStatusIndex}" Value="2">
                                                    <Setter Property="Background" Value="{StaticResource GoldAccent}"/>
                                                </DataTrigger>
                                            </Border.Triggers>
                                            <Label Text="Approved" FontSize="11" HorizontalOptions="Center" TextColor="{StaticResource DimmedText}">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label" Binding="{Binding SelectedStatusIndex}" Value="2">
                                                        <Setter Property="TextColor" Value="{StaticResource AppBackground}"/>
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnChargesFilterTapped" CommandParameter="2"/>
                                            </Border.GestureRecognizers>
                                        </Border>
                                        <Border Grid.Column="3" Background="Transparent" StrokeThickness="0" Padding="0,8">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="9"/></Border.StrokeShape>
                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border" Binding="{Binding SelectedStatusIndex}" Value="3">
                                                    <Setter Property="Background" Value="{StaticResource GoldAccent}"/>
                                                </DataTrigger>
                                            </Border.Triggers>
                                            <Label Text="Rejected" FontSize="11" HorizontalOptions="Center" TextColor="{StaticResource DimmedText}">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label" Binding="{Binding SelectedStatusIndex}" Value="3">
                                                        <Setter Property="TextColor" Value="{StaticResource AppBackground}"/>
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnChargesFilterTapped" CommandParameter="3"/>
                                            </Border.GestureRecognizers>
                                        </Border>
                                    </Grid>
                                </Border>

                                <VerticalStackLayout Spacing="12"
                                    BindableLayout.ItemsSource="{Binding Expenses}">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="models:ChargeDto">
                                            <controls:ExpenseItemView />
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>

                            </VerticalStackLayout>
                        </VerticalStackLayout>

                        <!-- ═══════════ PAYMENTS SECTION ═══════════ -->
                        <VerticalStackLayout Spacing="14">

                            <!-- Section header -->
                            <Grid ColumnDefinitions="*,Auto">
                                <HorizontalStackLayout Grid.Column="0" Spacing="6" VerticalOptions="Center">
                                    <HorizontalStackLayout.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding TogglePaymentsCommand}" />
                                    </HorizontalStackLayout.GestureRecognizers>
                                    <Label Text="{x:Static fonts:FluentUi.chevron_down_20_regular}"
                                           IsVisible="{Binding IsPaymentsExpanded}"
                                           FontFamily="{x:Static fonts:FluentUi.fontFamily}"
                                           FontSize="14"
                                           TextColor="{StaticResource MutedText}"
                                           VerticalOptions="Center" />
                                    <Label Text="{x:Static fonts:FluentUi.chevron_right_20_regular}"
                                           IsVisible="{Binding IsPaymentsExpanded, Converter={StaticResource InvertedBoolConverter}}"
                                           FontFamily="{x:Static fonts:FluentUi.fontFamily}"
                                           FontSize="14"
                                           TextColor="{StaticResource MutedText}"
                                           VerticalOptions="Center" />
                                    <Label Text="Payments"
                                           Style="{StaticResource SectionLabelStyle}"
                                           FontSize="13"
                                           TextColor="{StaticResource DimmedText}"
                                           VerticalOptions="Center" />
                                </HorizontalStackLayout>
                                <Button Grid.Column="1"
                                        Text="+ NEW"
                                        Command="{Binding AddPaymentCommand}"
                                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                                        BackgroundColor="Transparent"
                                        BorderColor="{StaticResource StrokeColor}"
                                        BorderWidth="1"
                                        TextColor="{StaticResource GoldAccent}"
                                        CornerRadius="12"
                                        FontSize="11"
                                        Padding="10,4"
                                        HeightRequest="28" />
                            </Grid>

                            <!-- Collapsible content -->
                            <VerticalStackLayout IsVisible="{Binding IsPaymentsExpanded}" Spacing="14">

                                <!-- Payments filter: native Grid guarantees equal-width tabs at any screen size -->
                                <Border Background="{StaticResource CardSurface}"
                                        Stroke="{StaticResource StrokeColor}"
                                        StrokeThickness="1"
                                        Padding="3">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12" />
                                    </Border.StrokeShape>
                                    <Grid ColumnDefinitions="*,*,*,*">
                                        <Border Grid.Column="0" Background="Transparent" StrokeThickness="0" Padding="0,8">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="9"/></Border.StrokeShape>
                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border" Binding="{Binding SelectedPaymentStatusIndex}" Value="0">
                                                    <Setter Property="Background" Value="{StaticResource GoldAccent}"/>
                                                </DataTrigger>
                                            </Border.Triggers>
                                            <Label Text="All" FontSize="11" HorizontalOptions="Center" TextColor="{StaticResource DimmedText}">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label" Binding="{Binding SelectedPaymentStatusIndex}" Value="0">
                                                        <Setter Property="TextColor" Value="{StaticResource AppBackground}"/>
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnPaymentsFilterTapped" CommandParameter="0"/>
                                            </Border.GestureRecognizers>
                                        </Border>
                                        <Border Grid.Column="1" Background="Transparent" StrokeThickness="0" Padding="0,8">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="9"/></Border.StrokeShape>
                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border" Binding="{Binding SelectedPaymentStatusIndex}" Value="1">
                                                    <Setter Property="Background" Value="{StaticResource GoldAccent}"/>
                                                </DataTrigger>
                                            </Border.Triggers>
                                            <Label Text="Pending" FontSize="11" HorizontalOptions="Center" TextColor="{StaticResource DimmedText}">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label" Binding="{Binding SelectedPaymentStatusIndex}" Value="1">
                                                        <Setter Property="TextColor" Value="{StaticResource AppBackground}"/>
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnPaymentsFilterTapped" CommandParameter="1"/>
                                            </Border.GestureRecognizers>
                                        </Border>
                                        <Border Grid.Column="2" Background="Transparent" StrokeThickness="0" Padding="0,8">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="9"/></Border.StrokeShape>
                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border" Binding="{Binding SelectedPaymentStatusIndex}" Value="2">
                                                    <Setter Property="Background" Value="{StaticResource GoldAccent}"/>
                                                </DataTrigger>
                                            </Border.Triggers>
                                            <Label Text="Approved" FontSize="11" HorizontalOptions="Center" TextColor="{StaticResource DimmedText}">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label" Binding="{Binding SelectedPaymentStatusIndex}" Value="2">
                                                        <Setter Property="TextColor" Value="{StaticResource AppBackground}"/>
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnPaymentsFilterTapped" CommandParameter="2"/>
                                            </Border.GestureRecognizers>
                                        </Border>
                                        <Border Grid.Column="3" Background="Transparent" StrokeThickness="0" Padding="0,8">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="9"/></Border.StrokeShape>
                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border" Binding="{Binding SelectedPaymentStatusIndex}" Value="3">
                                                    <Setter Property="Background" Value="{StaticResource GoldAccent}"/>
                                                </DataTrigger>
                                            </Border.Triggers>
                                            <Label Text="Rejected" FontSize="11" HorizontalOptions="Center" TextColor="{StaticResource DimmedText}">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label" Binding="{Binding SelectedPaymentStatusIndex}" Value="3">
                                                        <Setter Property="TextColor" Value="{StaticResource AppBackground}"/>
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnPaymentsFilterTapped" CommandParameter="3"/>
                                            </Border.GestureRecognizers>
                                        </Border>
                                    </Grid>
                                </Border>

                                <VerticalStackLayout Spacing="12"
                                    BindableLayout.ItemsSource="{Binding Payments}">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="models:PaymentDto">
                                            <controls:PaymentItemView />
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>

                            </VerticalStackLayout>

                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </ScrollView>
            </pullToRefresh:SfPullToRefresh.PullableContent>
        </pullToRefresh:SfPullToRefresh>

        <!-- Floating tab bar overlay -->
        <controls:CustomTabBar VerticalOptions="End" ActiveTabIndex="0" />

        <!-- Filter scrim -->
        <BoxView x:Name="FilterScrim"
                 BackgroundColor="#000000"
                 Opacity="0"
                 IsVisible="False"
                 InputTransparent="True">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnScrimTapped" />
            </BoxView.GestureRecognizers>
        </BoxView>

        <!-- Filter panel (slides in from right) -->
        <controls:FilterPanel x:Name="FilterPanelView"
                              BindingContext="{Binding}"
                              VerticalOptions="Fill"
                              HorizontalOptions="End"
                              CloseRequested="OnFilterPanelCloseRequested" />

    </Grid>
</ContentPage>
