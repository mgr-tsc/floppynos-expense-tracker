<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pageModels="clr-namespace:ExpenseTracker.PageModels"
             xmlns:sf="clr-namespace:Syncfusion.Maui.Toolkit.TextInputLayout;assembly=Syncfusion.Maui.Toolkit"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="ExpenseTracker.Pages.JoinHouseholdPage"
             x:DataType="pageModels:JoinHouseholdPageModel"
             Title="Join Household">

    <ContentPage.Resources>
        <ResourceDictionary>
            <toolkit:InvertedBoolConverter x:Key="InvertedBoolConverter" />
            <toolkit:IsNotNullConverter x:Key="IsNotNullConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="{StaticResource LayoutPadding}"
                             Spacing="{StaticResource LayoutSpacing}"
                             VerticalOptions="Center">

            <Label Text="Join a Household"
                   Style="{StaticResource LargeTitle}"
                   HorizontalOptions="Center"
                   Margin="0,0,0,20" />

            <Label Text="Enter the 5-digit code shared by your partner"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,20" />

            <sf:SfTextInputLayout Hint="Household Code">
                <Entry Text="{Binding Code}"
                       Keyboard="Numeric"
                       MaxLength="5"
                       HorizontalTextAlignment="Center"
                       FontSize="24"
                       SemanticProperties.Description="Household join code" />
            </sf:SfTextInputLayout>

            <Label Text="{Binding ErrorMessage}"
                   TextColor="Red"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />

            <Button Text="Join Household"
                    Command="{Binding JoinCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                    MinimumHeightRequest="{OnIdiom 48, Desktop=56}"
                    HorizontalOptions="Center"
                    Padding="24,12"
                    Margin="0,20,0,0" />

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               HorizontalOptions="Center" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>