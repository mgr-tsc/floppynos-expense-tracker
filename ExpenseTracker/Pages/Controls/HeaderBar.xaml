<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ExpenseTracker.Pages.Controls.HeaderBar">

    <Grid x:Name="HeaderBarLayout"
          ColumnDefinitions="*,Auto"
          Padding="0,8"
          VerticalOptions="Center">

        <Label Grid.Column="0"
               Text="{Binding UserName}"
               FontSize="28"
               FontFamily="SpaceGrotesk-Bold"
               FontAttributes="Bold"
               TextColor="White"
               VerticalOptions="Center" />

        <Border Grid.Column="1"
                WidthRequest="44"
                HeightRequest="44"
                HorizontalOptions="End"
                VerticalOptions="Center"
                StrokeThickness="0"
                Padding="0"
                Background="{StaticResource GoldAccent}">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="999" />
            </Border.StrokeShape>
            <Label Text="{Binding UserInitials}"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="{StaticResource AppBackground}"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
        </Border>
    </Grid>

</ContentView>
