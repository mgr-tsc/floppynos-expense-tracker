<?xml version="1.0" encoding="utf-8"?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:fonts="clr-namespace:ExpenseTracker.Resources.Fonts"
             x:Class="ExpenseTracker.Pages.Controls.HouseholdSwitcher">

    <Border Background="{StaticResource CardSurface}"
            Stroke="{StaticResource StrokeColor}"
            StrokeThickness="1"
            Padding="12,7"
            HorizontalOptions="Start">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="20" />
        </Border.StrokeShape>

        <HorizontalStackLayout Spacing="8" VerticalOptions="Center">

            <Label Text="{x:Static fonts:FluentUi.building_home_24_regular}"
                   FontFamily="{x:Static fonts:FluentUi.fontFamily}"
                   FontSize="16"
                   TextColor="{StaticResource GoldAccent}"
                   VerticalOptions="Center" />

            <Label Text="{Binding HouseholdName}"
                   FontSize="13"
                   FontFamily="SpaceGrotesk"
                   TextColor="White"
                   VerticalOptions="Center" />

            <Label Text="{x:Static fonts:FluentUi.chevron_down_20_regular}"
                   FontFamily="{x:Static fonts:FluentUi.fontFamily}"
                   FontSize="12"
                   TextColor="{StaticResource MutedText}"
                   VerticalOptions="Center" />

        </HorizontalStackLayout>
    </Border>

</ContentView>
