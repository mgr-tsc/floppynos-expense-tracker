<?xml version="1.0" encoding="utf-8" ?>
<Border
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:effectsView="clr-namespace:Syncfusion.Maui.Toolkit.EffectsView;assembly=Syncfusion.Maui.Toolkit"
    xmlns:pageModels="clr-namespace:ExpenseTracker.PageModels"
    xmlns:models="clr-namespace:ExpenseTracker.Models.Supabase"
    x:Class="ExpenseTracker.Pages.Controls.PaymentItemView"
    x:DataType="models:PaymentDto"
    Style="{StaticResource DarkCard}"
    Padding="0">

    <effectsView:SfEffectsView
        TouchDownEffects="Highlight"
        HighlightBackground="{StaticResource ElevatedSurface}">

        <Grid ColumnDefinitions="3,*">

            <!-- Gold left accent stripe (payments are always gold) -->
            <BoxView Grid.Column="0"
                     BackgroundColor="{StaticResource GoldAccent}" />

            <!-- Content -->
            <Grid Grid.Column="1"
                  ColumnDefinitions="*,Auto"
                  Padding="16,14">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer
                        Command="{Binding NavigateToPaymentCommand, Source={RelativeSource AncestorType={x:Type pageModels:MainPageModel}}, x:DataType=pageModels:MainPageModel}"
                        CommandParameter="{Binding .}" />
                </Grid.GestureRecognizers>

                <VerticalStackLayout Grid.Column="0" Spacing="4">
                    <Label Text="{Binding PaymentMethodLabel}"
                           Style="{StaticResource Body1Strong}"
                           LineBreakMode="TailTruncation" />
                    <Label Text="{Binding DisplayDate}"
                           Style="{StaticResource Caption1}"
                           TextColor="{StaticResource DimmedText}" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                    <Label Text="{Binding DisplayAmount}"
                           Style="{StaticResource Body1Strong}"
                           HorizontalTextAlignment="End" />
                    <Label Text="{Binding StatusLabel}"
                           Style="{StaticResource Caption2}"
                           TextColor="{Binding StatusColor}"
                           HorizontalTextAlignment="End" />
                </VerticalStackLayout>
            </Grid>

        </Grid>
    </effectsView:SfEffectsView>
</Border>
