<?xml version="1.0" encoding="utf-8" ?>
<Border
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:ExpenseTracker.Models"
    x:Class="ExpenseTracker.Pages.Controls.BalanceView"
    x:DataType="models:BalanceData"
    Style="{StaticResource DarkCard}"
    Padding="0">

    <Grid ColumnDefinitions="3,*">

        <!-- Gold left accent stripe -->
        <BoxView Grid.Column="0"
                 BackgroundColor="{StaticResource GoldAccent}" />

        <!-- Content area -->
        <VerticalStackLayout Grid.Column="1" Spacing="8" Padding="16,18">

            <Label Text="Your Balance"
                   Style="{StaticResource SectionLabelStyle}" />

            <Label Text="{Binding TotalOwed}"
                   Style="{StaticResource HeroAmountStyle}" />

            <Grid ColumnDefinitions="*,*" Margin="0,8,0,0">
                <VerticalStackLayout Grid.Column="0" Spacing="4">
                    <Label Text="{Binding PersonA.Name, StringFormat='{0} owes'}"
                           Style="{StaticResource Caption1}"
                           TextColor="{StaticResource DimmedText}" />
                    <Label Text="{Binding PersonAOwes, StringFormat='{0:C2}'}"
                           Style="{StaticResource Body1Strong}" />
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="1" Spacing="4">
                    <Label Text="{Binding PersonB.Name, StringFormat='{0} owes'}"
                           Style="{StaticResource Caption1}"
                           TextColor="{StaticResource DimmedText}" />
                    <Label Text="{Binding PersonBOwes, StringFormat='{0:C2}'}"
                           Style="{StaticResource Body1Strong}" />
                </VerticalStackLayout>
            </Grid>

        </VerticalStackLayout>
    </Grid>
</Border>
