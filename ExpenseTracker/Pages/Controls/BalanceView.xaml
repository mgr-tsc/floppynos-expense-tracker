<?xml version="1.0" encoding="utf-8" ?>
<Border
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:ExpenseTracker.Models"
    x:Class="ExpenseTracker.Pages.Controls.BalanceView"
    x:DataType="models:BalanceData"
    Style="{StaticResource DarkCard}"
    Padding="0">

    <Grid ColumnDefinitions="3,*">

        <!-- Gold left accent stripe -->
        <BoxView Grid.Column="0"
                 BackgroundColor="{StaticResource GoldAccent}" />

        <!-- Content area -->
        <VerticalStackLayout Grid.Column="1" Spacing="4" Padding="16,18">

            <Label Text="YOUR BALANCE"
                   Style="{StaticResource SectionLabelStyle}" />

            <Label Text="{Binding NetAmountFormatted}"
                   Style="{StaticResource HeroAmountStyle}" />

            <Label Text="{Binding BalanceNote}"
                   FontFamily="SpaceGrotesk"
                   FontSize="12"
                   TextColor="{StaticResource MutedText}"
                   Margin="0,4,0,0" />

        </VerticalStackLayout>
    </Grid>
</Border>
