<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ExpenseTracker.Pages.MockHomePage"
             Title=""
             Shell.NavBarIsVisible="False"
             BackgroundColor="#111111">

    <Grid RowDefinitions="*,Auto">

        <!-- ===================== SCROLL CONTENT ===================== -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="28,8,28,28" Spacing="32">
                <!-- ── HEADER ── -->
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="End">
                        <Label Text="GOOD MORNING"
                               TextColor="#666666"
                               FontSize="10"
                               FontFamily="OpenSansSemibold"
                               CharacterSpacing="2" />
                        <Label Text="ALEX"
                               TextColor="White"
                               FontSize="42"
                               FontFamily="OpenSansSemibold"
                               CharacterSpacing="-1"
                               LineHeight="0.95" />
                    </VerticalStackLayout>
                    <Border Grid.Column="1"
                            BackgroundColor="#D4AF37"
                            WidthRequest="44" HeightRequest="44"
                            StrokeThickness="0"
                            VerticalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="6" />
                        </Border.StrokeShape>
                        <Label Text="AL"
                               TextColor="#111111"
                               FontSize="15"
                               FontFamily="OpenSansSemibold"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>
                </Grid>

                <!-- ── BALANCE SECTION ── -->
                <VerticalStackLayout Spacing="16">

                    <!-- Household Card -->
                    <Border BackgroundColor="#1C1C1C"
                            Padding="18,16"
                            Stroke="#2A2A2A"
                            StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="2" />
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="0">
                            <!-- House icon box -->
                            <Border Grid.Column="0"
                                    BackgroundColor="#D4AF3720"
                                    WidthRequest="36" HeightRequest="36"
                                    StrokeThickness="0"
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="4" />
                                </Border.StrokeShape>
                                <Label Text="⌂"
                                       TextColor="#D4AF37"
                                       FontSize="16"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                            <!-- Household info -->
                            <VerticalStackLayout Grid.Column="1" Spacing="2"
                                                 Margin="12,0,0,0"
                                                 VerticalOptions="Center">
                                <Label Text="CURRENT HOUSEHOLD"
                                       TextColor="#666666"
                                       FontSize="9"
                                       FontFamily="OpenSansSemibold"
                                       CharacterSpacing="1.5" />
                                <Label Text="Sunset Apartment"
                                       TextColor="White"
                                       FontSize="14"
                                       FontFamily="OpenSansSemibold" />
                            </VerticalStackLayout>
                            <!-- Switch button -->
                            <Border Grid.Column="2"
                                    BackgroundColor="#282828"
                                    Padding="10,6"
                                    StrokeThickness="0"
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="2" />
                                </Border.StrokeShape>
                                <HorizontalStackLayout Spacing="5">
                                    <Label Text="⇅"
                                           TextColor="#A0A0A0"
                                           FontSize="11"
                                           VerticalOptions="Center" />
                                    <Label Text="SWITCH"
                                           TextColor="#A0A0A0"
                                           FontSize="9"
                                           FontFamily="OpenSansSemibold"
                                           CharacterSpacing="1"
                                           VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Summary Card (left gold border via Grid trick) -->
                    <Grid ColumnDefinitions="3,*">
                        <BoxView Grid.Column="0" BackgroundColor="#D4AF37" />
                        <Border Grid.Column="1"
                                BackgroundColor="#1C1C1C"
                                Padding="20,24"
                                StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="0" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="20">

                                <!-- Balance header row -->
                                <Grid ColumnDefinitions="*,Auto">
                                    <HorizontalStackLayout Grid.Column="0" Spacing="12" VerticalOptions="Center">
                                        <BoxView BackgroundColor="#D4AF37"
                                                 WidthRequest="3" HeightRequest="14"
                                                 VerticalOptions="Center" />
                                        <Label Text="BALANCE OVERVIEW"
                                               TextColor="#A0A0A0"
                                               FontSize="11"
                                               FontFamily="OpenSansSemibold"
                                               CharacterSpacing="2"
                                               VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                    <Label Grid.Column="1"
                                           Text="DETAILS"
                                           TextColor="#D4AF37"
                                           FontSize="11"
                                           FontFamily="OpenSansRegular"
                                           CharacterSpacing="1"
                                           VerticalOptions="Center" />
                                </Grid>

                                <!-- Total label + month badge -->
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Grid.Column="0"
                                           Text="TOTAL BALANCE"
                                           TextColor="#666666"
                                           FontSize="10"
                                           FontFamily="OpenSansSemibold"
                                           CharacterSpacing="1.5"
                                           VerticalOptions="Center" />
                                    <Border Grid.Column="1"
                                            BackgroundColor="#282828"
                                            Padding="8,4"
                                            StrokeThickness="0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="2" />
                                        </Border.StrokeShape>
                                        <HorizontalStackLayout Spacing="5">
                                            <Label Text="📅" FontSize="9" VerticalOptions="Center" />
                                            <Label Text="FEBRUARY"
                                                   TextColor="#666666"
                                                   FontSize="9"
                                                   FontFamily="OpenSansSemibold"
                                                   CharacterSpacing="1"
                                                   VerticalOptions="Center" />
                                        </HorizontalStackLayout>
                                    </Border>
                                </Grid>

                                <!-- Total amount -->
                                <Label Text="$2,340.50"
                                       TextColor="#D4AF37"
                                       FontSize="36"
                                       FontFamily="OpenSansSemibold"
                                       CharacterSpacing="-2" />

                                <!-- You Owe / Owed to You -->
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                    <Border Grid.Column="0"
                                            BackgroundColor="#282828"
                                            Padding="16,14"
                                            StrokeThickness="0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="2" />
                                        </Border.StrokeShape>
                                        <VerticalStackLayout Spacing="6">
                                            <Label Text="YOU OWE"
                                                   TextColor="#666666"
                                                   FontSize="9"
                                                   FontFamily="OpenSansSemibold"
                                                   CharacterSpacing="1.5" />
                                            <Label Text="$340.00"
                                                   TextColor="#F44336"
                                                   FontSize="22"
                                                   FontFamily="OpenSansSemibold"
                                                   CharacterSpacing="-1" />
                                        </VerticalStackLayout>
                                    </Border>
                                    <Border Grid.Column="1"
                                            BackgroundColor="#282828"
                                            Padding="16,14"
                                            StrokeThickness="0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="2" />
                                        </Border.StrokeShape>
                                        <VerticalStackLayout Spacing="6">
                                            <Label Text="OWED TO YOU"
                                                   TextColor="#666666"
                                                   FontSize="9"
                                                   FontFamily="OpenSansSemibold"
                                                   CharacterSpacing="1.5" />
                                            <Label Text="$690.50"
                                                   TextColor="#4CAF50"
                                                   FontSize="22"
                                                   FontFamily="OpenSansSemibold"
                                                   CharacterSpacing="-1" />
                                        </VerticalStackLayout>
                                    </Border>
                                </Grid>

                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                </VerticalStackLayout>

                <!-- ── CHARGES SECTION ── -->
                <VerticalStackLayout Spacing="16">

                    <!-- Charges header -->
                    <Grid ColumnDefinitions="*,Auto">
                        <HorizontalStackLayout Grid.Column="0" Spacing="10" VerticalOptions="Center">
                            <BoxView BackgroundColor="#D4AF37"
                                     WidthRequest="3" HeightRequest="14"
                                     VerticalOptions="Center" />
                            <Label Text="CHARGES"
                                   TextColor="#A0A0A0"
                                   FontSize="11"
                                   FontFamily="OpenSansSemibold"
                                   CharacterSpacing="2"
                                   VerticalOptions="Center" />
                            <!-- Count badge -->
                            <Border BackgroundColor="#D4AF3720"
                                    Padding="7,3"
                                    Stroke="#D4AF37"
                                    StrokeThickness="1">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="2" />
                                </Border.StrokeShape>
                                <Label Text="3"
                                       TextColor="#D4AF37"
                                       FontSize="9"
                                       FontFamily="OpenSansSemibold"
                                       CharacterSpacing="1" />
                            </Border>
                            <!-- Add button -->
                            <Border BackgroundColor="#D4AF37"
                                    Padding="12,8"
                                    StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="2" />
                                </Border.StrokeShape>
                                <Label Text="+ ADD"
                                       TextColor="#111111"
                                       FontSize="10"
                                       FontFamily="OpenSansSemibold"
                                       CharacterSpacing="1" />
                            </Border>
                        </HorizontalStackLayout>
                        <!-- Collapse chevron -->
                        <Border Grid.Column="1"
                                BackgroundColor="#1C1C1C"
                                WidthRequest="28" HeightRequest="28"
                                Stroke="#2A2A2A" StrokeThickness="1"
                                VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="2" />
                            </Border.StrokeShape>
                            <Label Text="↑"
                                   TextColor="#D4AF37"
                                   FontSize="14"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>
                    </Grid>

                    <!-- Segment: My Charges / Jordan's -->
                    <Border BackgroundColor="#1C1C1C"
                            HeightRequest="44"
                            Stroke="#2A2A2A" StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="2" />
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="*,*">
                            <Border Grid.Column="0"
                                    BackgroundColor="#D4AF37"
                                    StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="0" />
                                </Border.StrokeShape>
                                <Label Text="MY CHARGES"
                                       TextColor="#111111"
                                       FontSize="11"
                                       FontFamily="OpenSansSemibold"
                                       CharacterSpacing="1"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                            <Label Grid.Column="1"
                                   Text="JORDAN'S"
                                   TextColor="#666666"
                                   FontSize="11"
                                   FontFamily="OpenSansRegular"
                                   CharacterSpacing="1"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Border>

                    <!-- Status filter: Pending / Approved / Rejected -->
                    <Border BackgroundColor="#1C1C1C"
                            HeightRequest="38"
                            Stroke="#2A2A2A" StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="2" />
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="*,*,*">
                            <!-- Pending (active) -->
                            <Border Grid.Column="0"
                                    BackgroundColor="#D4AF37"
                                    StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="0" />
                                </Border.StrokeShape>
                                <HorizontalStackLayout Spacing="6"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center">
                                    <BoxView BackgroundColor="#111111"
                                             WidthRequest="6" HeightRequest="6"
                                             VerticalOptions="Center" />
                                    <Label Text="PENDING"
                                           TextColor="#111111"
                                           FontSize="10"
                                           FontFamily="OpenSansSemibold"
                                           CharacterSpacing="1.5"
                                           VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </Border>
                            <!-- Approved -->
                            <HorizontalStackLayout Grid.Column="1" Spacing="6"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center">
                                <BoxView BackgroundColor="#4CAF50"
                                         WidthRequest="6" HeightRequest="6"
                                         VerticalOptions="Center" />
                                <Label Text="APPROVED"
                                       TextColor="#666666"
                                       FontSize="10"
                                       FontFamily="OpenSansSemibold"
                                       CharacterSpacing="1.5"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <!-- Rejected -->
                            <HorizontalStackLayout Grid.Column="2" Spacing="6"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center">
                                <BoxView BackgroundColor="#F44336"
                                         WidthRequest="6" HeightRequest="6"
                                         VerticalOptions="Center" />
                                <Label Text="REJECTED"
                                       TextColor="#666666"
                                       FontSize="10"
                                       FontFamily="OpenSansSemibold"
                                       CharacterSpacing="1.5"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Grid>
                    </Border>

                    <!-- Charge Card 1: Grocery Store — PENDING -->
                    <Border BackgroundColor="#1C1C1C"
                            Stroke="#2A2A2A" StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="2" />
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="4,*">
                            <BoxView Grid.Column="0" BackgroundColor="#D4AF37" />
                            <Grid Grid.Column="1"
                                  ColumnDefinitions="*,Auto"
                                  Padding="18,16">
                                <VerticalStackLayout Grid.Column="0" Spacing="5" VerticalOptions="Center">
                                    <Label Text="GROCERY STORE"
                                           TextColor="White"
                                           FontSize="13"
                                           FontFamily="OpenSansSemibold"
                                           CharacterSpacing="0.5" />
                                    <Label Text="Feb 15  ·  Shared"
                                           TextColor="#666666"
                                           FontSize="11"
                                           FontFamily="OpenSansRegular" />
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" Spacing="8" HorizontalOptions="End">
                                    <Label Text="$87.40"
                                           TextColor="White"
                                           FontSize="18"
                                           FontFamily="OpenSansSemibold"
                                           CharacterSpacing="-0.5"
                                           HorizontalOptions="End" />
                                    <Border BackgroundColor="#D4AF3720"
                                            Padding="8,4"
                                            StrokeThickness="0"
                                            HorizontalOptions="End">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="2" />
                                        </Border.StrokeShape>
                                        <HorizontalStackLayout Spacing="5">
                                            <BoxView BackgroundColor="#D4AF37"
                                                     WidthRequest="6" HeightRequest="6"
                                                     VerticalOptions="Center" />
                                            <Label Text="PENDING"
                                                   TextColor="#D4AF37"
                                                   FontSize="9"
                                                   FontFamily="OpenSansSemibold"
                                                   CharacterSpacing="1" />
                                        </HorizontalStackLayout>
                                    </Border>
                                    <Border BackgroundColor="#282828"
                                            WidthRequest="26" HeightRequest="26"
                                            StrokeThickness="0"
                                            HorizontalOptions="End">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="2" />
                                        </Border.StrokeShape>
                                        <Label Text="•••"
                                               TextColor="#A0A0A0"
                                               FontSize="10"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center" />
                                    </Border>
                                </VerticalStackLayout>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Charge Card 2: Netflix — PAID -->
                    <Border BackgroundColor="#1C1C1C"
                            Stroke="#2A2A2A" StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="2" />
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="4,*">
                            <BoxView Grid.Column="0" BackgroundColor="#4CAF50" />
                            <Grid Grid.Column="1"
                                  ColumnDefinitions="*,Auto"
                                  Padding="18,16">
                                <VerticalStackLayout Grid.Column="0" Spacing="5" VerticalOptions="Center">
                                    <Label Text="NETFLIX SUBSCRIPTION"
                                           TextColor="White"
                                           FontSize="13"
                                           FontFamily="OpenSansSemibold"
                                           CharacterSpacing="0.5" />
                                    <Label Text="Feb 14  ·  Personal"
                                           TextColor="#666666"
                                           FontSize="11"
                                           FontFamily="OpenSansRegular" />
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" Spacing="8" HorizontalOptions="End">
                                    <Label Text="$22.00"
                                           TextColor="White"
                                           FontSize="18"
                                           FontFamily="OpenSansSemibold"
                                           CharacterSpacing="-0.5"
                                           HorizontalOptions="End" />
                                    <Border BackgroundColor="#4CAF5020"
                                            Padding="8,4"
                                            StrokeThickness="0"
                                            HorizontalOptions="End">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="2" />
                                        </Border.StrokeShape>
                                        <HorizontalStackLayout Spacing="5">
                                            <BoxView BackgroundColor="#4CAF50"
                                                     WidthRequest="6" HeightRequest="6"
                                                     VerticalOptions="Center" />
                                            <Label Text="PAID"
                                                   TextColor="#4CAF50"
                                                   FontSize="9"
                                                   FontFamily="OpenSansSemibold"
                                                   CharacterSpacing="1" />
                                        </HorizontalStackLayout>
                                    </Border>
                                    <Border BackgroundColor="#282828"
                                            WidthRequest="26" HeightRequest="26"
                                            StrokeThickness="0"
                                            HorizontalOptions="End">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="2" />
                                        </Border.StrokeShape>
                                        <Label Text="•••"
                                               TextColor="#A0A0A0"
                                               FontSize="10"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center" />
                                    </Border>
                                </VerticalStackLayout>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Charge Card 3: Electric Bill — SETTLED -->
                    <Border BackgroundColor="#1C1C1C"
                            Stroke="#2A2A2A" StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="2" />
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="4,*">
                            <BoxView Grid.Column="0" BackgroundColor="#3A3A3A" />
                            <Grid Grid.Column="1"
                                  ColumnDefinitions="*,Auto"
                                  Padding="18,16">
                                <VerticalStackLayout Grid.Column="0" Spacing="5" VerticalOptions="Center">
                                    <Label Text="ELECTRIC BILL"
                                           TextColor="White"
                                           FontSize="13"
                                           FontFamily="OpenSansSemibold"
                                           CharacterSpacing="0.5" />
                                    <Label Text="Feb 10  ·  Shared"
                                           TextColor="#666666"
                                           FontSize="11"
                                           FontFamily="OpenSansRegular" />
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" Spacing="8" HorizontalOptions="End">
                                    <Label Text="$145.80"
                                           TextColor="White"
                                           FontSize="18"
                                           FontFamily="OpenSansSemibold"
                                           CharacterSpacing="-0.5"
                                           HorizontalOptions="End" />
                                    <Border BackgroundColor="#282828"
                                            Padding="8,4"
                                            StrokeThickness="0"
                                            HorizontalOptions="End">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="2" />
                                        </Border.StrokeShape>
                                        <HorizontalStackLayout Spacing="5">
                                            <BoxView BackgroundColor="#666666"
                                                     WidthRequest="6" HeightRequest="6"
                                                     VerticalOptions="Center" />
                                            <Label Text="SETTLED"
                                                   TextColor="#666666"
                                                   FontSize="9"
                                                   FontFamily="OpenSansSemibold"
                                                   CharacterSpacing="1" />
                                        </HorizontalStackLayout>
                                    </Border>
                                </VerticalStackLayout>
                            </Grid>
                        </Grid>
                    </Border>

                </VerticalStackLayout>

                <!-- ── PAYMENTS SECTION ── -->
                <VerticalStackLayout Spacing="0">

                    <!-- Payments header -->
                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,16">
                        <HorizontalStackLayout Grid.Column="0" Spacing="10" VerticalOptions="Center">
                            <BoxView BackgroundColor="#D4AF37"
                                     WidthRequest="3" HeightRequest="14"
                                     VerticalOptions="Center" />
                            <Label Text="PAYMENTS"
                                   TextColor="#A0A0A0"
                                   FontSize="11"
                                   FontFamily="OpenSansSemibold"
                                   CharacterSpacing="2"
                                   VerticalOptions="Center" />
                            <!-- Badge -->
                            <Border BackgroundColor="#4CAF5020"
                                    Padding="7,3"
                                    Stroke="#4CAF50"
                                    StrokeThickness="1">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="2" />
                                </Border.StrokeShape>
                                <Label Text="1"
                                       TextColor="#4CAF50"
                                       FontSize="9"
                                       FontFamily="OpenSansSemibold"
                                       CharacterSpacing="1" />
                            </Border>
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Grid.Column="1" Spacing="10" VerticalOptions="Center">
                            <!-- Add button -->
                            <Border BackgroundColor="#D4AF37"
                                    Padding="12,8"
                                    StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="2" />
                                </Border.StrokeShape>
                                <Label Text="+ ADD"
                                       TextColor="#111111"
                                       FontSize="10"
                                       FontFamily="OpenSansSemibold"
                                       CharacterSpacing="1" />
                            </Border>
                            <!-- Chevron -->
                            <Border BackgroundColor="#1C1C1C"
                                    WidthRequest="28" HeightRequest="28"
                                    Stroke="#2A2A2A" StrokeThickness="1">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="2" />
                                </Border.StrokeShape>
                                <Label Text="↓"
                                       TextColor="#666666"
                                       FontSize="14"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                        </HorizontalStackLayout>
                    </Grid>

                    <!-- Existing payment row -->
                    <Border BackgroundColor="#1C1C1C"
                            Stroke="#2A2A2A" StrokeThickness="1"
                            Margin="0,0,0,12">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="2" />
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="4,*">
                            <BoxView Grid.Column="0" BackgroundColor="#4CAF50" />
                            <Grid Grid.Column="1"
                                  ColumnDefinitions="*,Auto"
                                  Padding="16,14">
                                <VerticalStackLayout Grid.Column="0" Spacing="4" VerticalOptions="Center">
                                    <Label Text="PAYMENT TO JORDAN"
                                           TextColor="White"
                                           FontSize="13"
                                           FontFamily="OpenSansSemibold"
                                           CharacterSpacing="0.5" />
                                    <HorizontalStackLayout Spacing="8">
                                        <Border BackgroundColor="#282828"
                                                Padding="8,3"
                                                StrokeThickness="0">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="2" />
                                            </Border.StrokeShape>
                                            <Label Text="ZELLE"
                                                   TextColor="#A0A0A0"
                                                   FontSize="9"
                                                   FontFamily="OpenSansSemibold" />
                                        </Border>
                                        <Label Text="Feb 16"
                                               TextColor="#666666"
                                               FontSize="11"
                                               FontFamily="OpenSansRegular"
                                               VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" Spacing="6" HorizontalOptions="End">
                                    <Label Text="$340.00"
                                           TextColor="#4CAF50"
                                           FontSize="18"
                                           FontFamily="OpenSansSemibold"
                                           CharacterSpacing="-0.5"
                                           HorizontalOptions="End" />
                                    <Border BackgroundColor="#4CAF5020"
                                            Padding="8,4"
                                            StrokeThickness="0"
                                            HorizontalOptions="End">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="2" />
                                        </Border.StrokeShape>
                                        <HorizontalStackLayout Spacing="5">
                                            <BoxView BackgroundColor="#4CAF50"
                                                     WidthRequest="6" HeightRequest="6"
                                                     VerticalOptions="Center" />
                                            <Label Text="CONFIRMED"
                                                   TextColor="#4CAF50"
                                                   FontSize="9"
                                                   FontFamily="OpenSansSemibold"
                                                   CharacterSpacing="1" />
                                        </HorizontalStackLayout>
                                    </Border>
                                </VerticalStackLayout>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Add Payment Form (left gold border via Grid trick) -->
                    <Grid ColumnDefinitions="3,*">
                        <BoxView Grid.Column="0" BackgroundColor="#D4AF37" />
                        <Border Grid.Column="1"
                                BackgroundColor="#1C1C1C"
                                StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="0" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="20" Padding="18,18,18,20">

                                <!-- Form header -->
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Grid.Column="0"
                                           Text="NEW PAYMENT"
                                           TextColor="#D4AF37"
                                           FontSize="10"
                                           FontFamily="OpenSansSemibold"
                                           CharacterSpacing="2"
                                           VerticalOptions="Center" />
                                    <Border Grid.Column="1"
                                            BackgroundColor="#282828"
                                            WidthRequest="22" HeightRequest="22"
                                            StrokeThickness="0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="2" />
                                        </Border.StrokeShape>
                                        <Label Text="✕"
                                               TextColor="#666666"
                                               FontSize="10"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center" />
                                    </Border>
                                </Grid>

                                <!-- Amount field -->
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="AMOUNT"
                                           TextColor="#666666"
                                           FontSize="10"
                                           FontFamily="OpenSansSemibold"
                                           CharacterSpacing="2" />
                                    <Border BackgroundColor="#282828"
                                            HeightRequest="52"
                                            Padding="16,0"
                                            StrokeThickness="0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="2" />
                                        </Border.StrokeShape>
                                        <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                            <Label Text="$"
                                                   TextColor="#D4AF37"
                                                   FontSize="22"
                                                   FontFamily="OpenSansSemibold"
                                                   VerticalOptions="Center" />
                                            <BoxView BackgroundColor="#3A3A3A"
                                                     WidthRequest="1" HeightRequest="24"
                                                     VerticalOptions="Center" />
                                            <Label Text="0.00"
                                                   TextColor="#3A3A3A"
                                                   FontSize="22"
                                                   FontFamily="OpenSansSemibold"
                                                   CharacterSpacing="-0.5"
                                                   VerticalOptions="Center" />
                                        </HorizontalStackLayout>
                                    </Border>
                                </VerticalStackLayout>

                                <!-- Charge select field -->
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="CHARGE"
                                           TextColor="#666666"
                                           FontSize="10"
                                           FontFamily="OpenSansSemibold"
                                           CharacterSpacing="2" />
                                    <Border BackgroundColor="#282828"
                                            HeightRequest="48"
                                            Padding="16,0"
                                            StrokeThickness="0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="2" />
                                        </Border.StrokeShape>
                                        <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                                            <Label Grid.Column="0"
                                                   Text="Select a charge..."
                                                   TextColor="#666666"
                                                   FontSize="13"
                                                   FontFamily="OpenSansRegular"
                                                   VerticalOptions="Center" />
                                            <Label Grid.Column="1"
                                                   Text="↓"
                                                   TextColor="#666666"
                                                   FontSize="14"
                                                   VerticalOptions="Center" />
                                        </Grid>
                                    </Border>
                                </VerticalStackLayout>

                                <!-- Payment method field -->
                                <VerticalStackLayout Spacing="10">
                                    <Label Text="PAYMENT METHOD"
                                           TextColor="#666666"
                                           FontSize="10"
                                           FontFamily="OpenSansSemibold"
                                           CharacterSpacing="2" />
                                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                                        <!-- Zelle (active) -->
                                        <Border Grid.Column="0"
                                                BackgroundColor="#D4AF37"
                                                HeightRequest="52"
                                                StrokeThickness="0">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="2" />
                                            </Border.StrokeShape>
                                            <VerticalStackLayout Spacing="4"
                                                                 HorizontalOptions="Center"
                                                                 VerticalOptions="Center">
                                                <Label Text="⚡"
                                                       FontSize="16"
                                                       HorizontalOptions="Center" />
                                                <Label Text="ZELLE"
                                                       TextColor="#111111"
                                                       FontSize="9"
                                                       FontFamily="OpenSansSemibold"
                                                       CharacterSpacing="0.5"
                                                       HorizontalOptions="Center" />
                                            </VerticalStackLayout>
                                        </Border>
                                        <!-- Check -->
                                        <Border Grid.Column="1"
                                                BackgroundColor="#1C1C1C"
                                                HeightRequest="52"
                                                Stroke="#2A2A2A" StrokeThickness="1">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="2" />
                                            </Border.StrokeShape>
                                            <VerticalStackLayout Spacing="4"
                                                                 HorizontalOptions="Center"
                                                                 VerticalOptions="Center">
                                                <Label Text="📄"
                                                       FontSize="16"
                                                       HorizontalOptions="Center" />
                                                <Label Text="CHECK"
                                                       TextColor="#666666"
                                                       FontSize="9"
                                                       FontFamily="OpenSansSemibold"
                                                       CharacterSpacing="0.5"
                                                       HorizontalOptions="Center" />
                                            </VerticalStackLayout>
                                        </Border>
                                        <!-- Cash -->
                                        <Border Grid.Column="2"
                                                BackgroundColor="#1C1C1C"
                                                HeightRequest="52"
                                                Stroke="#2A2A2A" StrokeThickness="1">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="2" />
                                            </Border.StrokeShape>
                                            <VerticalStackLayout Spacing="4"
                                                                 HorizontalOptions="Center"
                                                                 VerticalOptions="Center">
                                                <Label Text="💵"
                                                       FontSize="16"
                                                       HorizontalOptions="Center" />
                                                <Label Text="CASH"
                                                       TextColor="#666666"
                                                       FontSize="9"
                                                       FontFamily="OpenSansSemibold"
                                                       CharacterSpacing="0.5"
                                                       HorizontalOptions="Center" />
                                            </VerticalStackLayout>
                                        </Border>
                                    </Grid>
                                </VerticalStackLayout>

                                <!-- Submit button -->
                                <Border BackgroundColor="#D4AF37"
                                        HeightRequest="48"
                                        StrokeThickness="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="2" />
                                    </Border.StrokeShape>
                                    <HorizontalStackLayout Spacing="10"
                                                           HorizontalOptions="Center"
                                                           VerticalOptions="Center">
                                        <Label Text="➤"
                                               TextColor="#111111"
                                               FontSize="12"
                                               VerticalOptions="Center" />
                                        <Label Text="SUBMIT PAYMENT"
                                               TextColor="#111111"
                                               FontSize="11"
                                               FontFamily="OpenSansSemibold"
                                               CharacterSpacing="2"
                                               VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                </Border>

                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
        <!-- ===================== BOTTOM TAB BAR ===================== -->
        <Border Grid.Row="1"
                BackgroundColor="#111111"
                Padding="21,12,21,21"
                StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0" />
            </Border.StrokeShape>
            <Border BackgroundColor="#1C1C1C"
                    HeightRequest="60"
                    Padding="5,4"
                    Stroke="#2A2A2A" StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="36" />
                </Border.StrokeShape>
                <Grid ColumnDefinitions="*,*,*">
                    <!-- HOME (active) -->
                    <Border Grid.Column="0"
                            BackgroundColor="#D4AF37"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="26" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="4"
                                             HorizontalOptions="Center"
                                             VerticalOptions="Center">
                            <Label Text="⌂"
                                   TextColor="#111111"
                                   FontSize="17"
                                   HorizontalOptions="Center" />
                            <Label Text="HOME"
                                   TextColor="#111111"
                                   FontSize="9"
                                   FontFamily="OpenSansSemibold"
                                   CharacterSpacing="0.5"
                                   HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>
                    <!-- CARDS -->
                    <VerticalStackLayout Grid.Column="1" Spacing="4"
                                         HorizontalOptions="Center"
                                         VerticalOptions="Center">
                        <Label Text="💳"
                               FontSize="17"
                               HorizontalOptions="Center" />
                        <Label Text="CARDS"
                               TextColor="#666666"
                               FontSize="9"
                               FontFamily="OpenSansRegular"
                               CharacterSpacing="0.5"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                    <!-- SETTINGS -->
                    <VerticalStackLayout Grid.Column="2" Spacing="4"
                                         HorizontalOptions="Center"
                                         VerticalOptions="Center">
                        <Label Text="⚙"
                               TextColor="#666666"
                               FontSize="17"
                               HorizontalOptions="Center" />
                        <Label Text="SETTINGS"
                               TextColor="#666666"
                               FontSize="9"
                               FontFamily="OpenSansRegular"
                               CharacterSpacing="0.5"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Grid>
            </Border>
        </Border>
    </Grid>
</ContentPage>
